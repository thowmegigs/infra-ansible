# {{ ansible_managed }}
listen:
  port: {{ nginxlog_exporter_port }}
  address: "127.0.0.1"

namespaces:
  - name: nginx
    # single-quoted: the format contains double quotes ($request etc.)
    format: '{{ nginx_monitoring_log_format }}'
    source:
      files:
{% for s in nginx_sites %}
        - {{ nginx_log_dir }}/{{ s.name }}.access.log
{% endfor %}
    labels:
      service: nginx
