# {{ ansible_managed }}
[Unit]
Description=Prometheus nginx log exporter
After=network.target nginx.service

[Service]
Type=simple
User=root
ExecStart={{ nginxlog_exporter_bin }} -config-file {{ nginxlog_exporter_config_dir }}/config.yml
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
