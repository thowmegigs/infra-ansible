# {{ ansible_managed }}
SECRET_KEY={{ vault_glitchtip_secret_key }}
DATABASE_URL=postgres://glitchtip:{{ vault_glitchtip_postgres_password | urlencode }}@postgres:5432/glitchtip
REDIS_URL=redis://redis:6379/0
PORT=8080
{% if glitchtip_expose_via_nginx | default(false) %}
GLITCHTIP_DOMAIN=https://{{ glitchtip_domain }}
{% else %}
GLITCHTIP_DOMAIN=http://{{ ansible_default_ipv4.address | default('127.0.0.1') }}:{{ glitchtip_listen_port }}
{% endif %}
DEFAULT_FROM_EMAIL={{ glitchtip_from_email }}
EMAIL_URL=smtp://{{ alert_smtp_user | urlencode }}:{{ vault_alert_smtp_password | urlencode }}@{{ alert_smtp_host }}:{{ alert_smtp_port }}
CELERY_WORKER_AUTOSCALE=1,3
ENABLE_OPEN_USER_REGISTRATION=False
GLITCHTIP_MAX_EVENT_LIFE_DAYS=30
