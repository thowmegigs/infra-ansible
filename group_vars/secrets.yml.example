---
# ===========================================================================
# TEMPLATE for group_vars/secrets.yml — copy to secrets.yml and fill real values.
#
#   cp group_vars/secrets.yml.example group_vars/secrets.yml
#   # edit the values, then either:
#   ansible-vault encrypt group_vars/secrets.yml      # commit encrypted, OR
#   # keep it plain and git-ignored (default) and scp it to the VPS like env/.
#
# secrets.yml is GIT-IGNORED (it holds real credentials). Transfer it to the VPS
# out-of-band:  scp group_vars/secrets.yml root@<SERVER_IP>:/root/infra-ansible/group_vars/
#
# Passwords here MUST match the DB_PASSWORD / user used in your env/*/.env files.
# ===========================================================================
vault_app_db_password:        "CHANGE_ME_appuser_password"        # MySQL appuser
vault_phpmyadmin_password:    "CHANGE_ME_admin_password"          # MySQL 'admin' + phpMyAdmin login
vault_grafana_admin_password: "CHANGE_ME_grafana_admin"           # Grafana 'admin' login
vault_mysql_exporter_password: "CHANGE_ME_mysql_exporter"         # local mysqld_exporter user

# Alerting / GlitchTip
vault_alert_smtp_password:    "CHANGE_ME_smtp_password"           # SMTP pass for Grafana email alerts
vault_glitchtip_secret_key:   "CHANGE_ME_glitchtip_secret_key_50_random_chars"
vault_glitchtip_postgres_password: "CHANGE_ME_glitchtip_pg_password"
